# ════════════════════════════════════════════════════════════════════
#  Enzi's Immobilienverwaltung — Backend Environment Variables
# ════════════════════════════════════════════════════════════════════
#  LOKAL:       Kopiere diese Datei nach .env und passe Werte an
#  PRODUKTION:  Setze diese Werte in den Fly.io Secrets
#  NIEMALS .env in Git committen!
# ════════════════════════════════════════════════════════════════════

# ── Datenbank (PostgreSQL) ──────────────────────────────────────────
# Lokal:      siehe docker-compose.yml
# Produktion: Neon, Supabase oder Fly.io Postgres → Connection-String einfügen
DATABASE_URL="postgresql://immo_user:secret@localhost:5432/immo_manager_dev?schema=public"

# ── Redis (BullMQ Job Queue für Dokumenten-Extraktion) ─────────────
# Lokal:      siehe docker-compose.yml
# Produktion: Upstash Redis (kostenlos) → rediss://... Connection-String
REDIS_URL="redis://localhost:6379"

# ── JWT ─────────────────────────────────────────────────────────────
# WICHTIG in Production: 64+ Zeichen Zufalls-String (z.B. via `openssl rand -hex 32`)
JWT_SECRET="change-me-to-a-random-256-bit-secret-in-production"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── Server ──────────────────────────────────────────────────────────
PORT=3000
HOST="0.0.0.0"
NODE_ENV="development"
LOG_LEVEL="debug"

# ── S3-kompatibler Datei-Speicher ───────────────────────────────────
# Lokal:      MinIO (siehe docker-compose.yml)
# Produktion: Cloudflare R2 (kostenlos bis 10 GB)
#             Endpoint:  https://<account-id>.r2.cloudflarestorage.com
#             Region:    auto
S3_ENDPOINT="http://localhost:9000"
S3_BUCKET="immo-documents"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_REGION="eu-central-1"
S3_FORCE_PATH_STYLE="true"

# ── Anthropic Claude (KI für Dokumenten-Extraktion + Enzi-Chatbot) ─
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL="claude-sonnet-4-6"

# ── CORS ────────────────────────────────────────────────────────────
# Lokal:      automatisch erlaubt (siehe server.ts)
# Produktion: URL deines Vercel-Frontends, z.B. https://enzi-immo.vercel.app
#             Mehrere mit Komma trennen
CORS_ORIGIN="http://localhost:3001"

# ── Rate Limiting ──────────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ── Extraction Pipeline ────────────────────────────────────────────
EXTRACTION_CONCURRENCY=3
