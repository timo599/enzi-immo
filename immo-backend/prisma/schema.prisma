// ============================================================
// ImmoManager Pro – Prisma Schema v1.0
// PostgreSQL 16+
// ============================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto, pg_trgm, unaccent]
}

// ── ENUMS ────────────────────────────────────────────────────

enum Heizungsart {
  oel
  gas
  fernwaerme
  strom
  waermepumpe
  pellets
  sonstiges
}

enum Einheitstyp {
  wohnung
  gewerbe
  buero
  laden
  lager
  stellplatz
  praxis
  loft
  sonstiges
}

enum Mietart {
  wohnraum
  gewerbe
}

enum UserRole {
  admin
  verwalter
  assistent
  eigentuemer_readonly
}

enum ExtractionStatus {
  pending
  processing
  extracted
  needs_review
  reviewed
  failed
  manual
}

enum MatchingStatus {
  unmatched
  auto_matched
  manually_matched
  ambiguous
  ignored
}

enum Buchungstyp {
  miete
  nk_vorauszahlung
  miete_und_nk
  nk_nachzahlung
  kaution
  nk_guthaben
  sonstiges
}

enum AbrechnungStatus {
  entwurf
  in_pruefung
  freigegeben
  versendet
  abgeschlossen
}

enum AmpelStatus {
  faellig
  bald_faellig
  geplant
  kein_handlungsbedarf
  manuelle_pruefung
}

enum Erhoehungstyp {
  staffel
  index
  vertraglich
  sonstig
}

enum Umlageschluessel {
  wohnflaeche
  gesamtflaeche
  personenanzahl
  verbrauchsmessung
  miteigentumsanteile
  gleiche_teile
}

enum Umlagefaehig {
  ja
  nein
  teilweise
}

enum PostenStatus {
  offen
  teilbezahlt
  bezahlt
  storniert
}

enum Vollstaendigkeitsstatus {
  vollstaendig
  kosten_ohne_verbrauch
  fehlt
}

enum Verbrauchstyp {
  oel
  strom_gemein
  strom_einheit
  gas
  wasser_kalt
  wasser_warm
  fernwaerme
}

enum Plan {
  starter
  professional
  enterprise
}

enum DokumentKategorie {
  rechnung
  mietvertrag
  mietvertrag_anlage
  kuendigung
  uebergabeprotokoll
  minol
  zaehler_foto
  zaehlerstand
  betriebskostenabrechnung
  versicherung
  grundsteuer
  korrespondenz
  ausweis
  bankverbindung
  sonstiges
}

// ── MODELS ───────────────────────────────────────────────────

model Tenant {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  slug       String   @unique
  plan       Plan     @default(starter)
  aktiv      Boolean  @default(true)
  erstelltAm DateTime @default(now()) @map("erstellt_am")

  users                 User[]
  firmen                Firma[]
  objekte               Objekt[]
  einheiten             Einheit[]
  mieter                Mieter[]
  mietvertraege         Mietvertrag[]
  kostenarten           Kostenart[]
  bankkonten            Bankkonto[]
  lieferanten           Lieferant[]
  abrechnungszeitraeume Abrechnungszeitraum[]
  dokumente             Dokument[]
  kostenpositionen      Kostenposition[]
  nkAbrechnungen        NkAbrechnung[]
  verbrauchserfassungen Verbrauchserfassung[]
  kontoauszuege         Kontoauszug[]
  buchungszeilen        Buchungszeile[]
  offenePosten          OffenerPosten[]
  mieterhoehungen       Mieterhoehung[]
  exporte               Export[]
  zaehler               Zaehler[]
  lernmodusSessionen    LernmodusSession[]
  einheitLernwissen     EinheitLernwissen[]
  kostenartLernwissen   KostenartLernwissen[]

  @@map("tenants")
}

model User {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  email        String
  passwordHash String    @map("password_hash")
  vorname      String?
  nachname     String?
  rolle        UserRole  @default(verwalter)
  aktiv        Boolean   @default(true)
  letzterLogin DateTime? @map("letzter_login")
  erstelltAm   DateTime  @default(now()) @map("erstellt_am")

  tenant                   Tenant             @relation(fields: [tenantId], references: [id])
  erstellteObjekte         Objekt[]           @relation("ObjektErsteller")
  erstellteVertraege       Mietvertrag[]      @relation("VertragErsteller")
  reviewedExtraktionen     DokExtraktion[]    @relation("ExtractionReviewer")
  freigegebeneAbrechnungen NkAbrechnung[]     @relation("AbrechnungFreigeber")
  erstellteAbrechnungen    NkAbrechnung[]     @relation("AbrechnungErsteller")
  bestaetigteMatchings     MatchingErgebnis[] @relation("MatchingBestaetiger")
  zugeordneteBuchungen     Buchungszeile[]    @relation("BuchungZuordner")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

model Firma {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  name       String
  rechtsform String?
  strasse    String?
  plz        String?
  stadt      String?
  notizen    String?
  aktiv      Boolean  @default(true)
  erstelltAm DateTime @default(now()) @map("erstellt_am")

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  objekte Objekt[]

  @@index([tenantId])
  @@map("firmen")
}

model Objekt {
  id                  String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            String      @map("tenant_id") @db.Uuid
  firmaId             String?     @map("firma_id") @db.Uuid
  bezeichnung         String
  strasse             String
  hausnummer          String
  plz                 String
  stadt               String
  bundesland          String?
  baujahr             Int?
  heizungsart         Heizungsart
  wohnflaecheGesamtM2 Decimal     @map("wohnflaeche_gesamt_m2") @db.Decimal(10, 2)
  nutzflaecheGesamtM2 Decimal?    @map("nutzflaeche_gesamt_m2") @db.Decimal(10, 2)
  meaGesamt           Int         @default(1000) @map("mea_gesamt")
  notizen             String?
  aktiv               Boolean     @default(true)
  erstelltAm          DateTime    @default(now()) @map("erstellt_am")
  erstelltVon         String?     @map("erstellt_von") @db.Uuid
  geaendertAm         DateTime?   @map("geaendert_am")
  deletedAt           DateTime?   @map("deleted_at")

  tenant                Tenant                @relation(fields: [tenantId], references: [id])
  firma                 Firma?                @relation(fields: [firmaId], references: [id])
  ersteller             User?                 @relation("ObjektErsteller", fields: [erstelltVon], references: [id])
  einheiten             Einheit[]
  umlageschluessel      UmlageschluesselEintrag[]
  abrechnungszeitraeume Abrechnungszeitraum[]
  verbrauchserfassungen Verbrauchserfassung[]
  bankkontoObjekte      BankkontoObjekt[]
  zaehler               Zaehler[]
  dokumente             Dokument[]

  @@index([tenantId])
  @@map("objekte")
}

model Einheit {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String      @map("tenant_id") @db.Uuid
  objektId      String      @map("objekt_id") @db.Uuid
  bezeichnung   String
  einheitenTyp  Einheitstyp @default(wohnung) @map("einheiten_typ")
  wohnflaecheM2 Decimal?    @map("wohnflaeche_m2") @db.Decimal(8, 2)
  nutzflaecheM2 Decimal?    @map("nutzflaeche_m2") @db.Decimal(8, 2)
  etage         String?
  meaAnteil     Int?        @map("mea_anteil")
  personenAnzahl Int?       @map("personen_anzahl")
  aktiv         Boolean     @default(true)
  notizen       String?
  erstelltAm    DateTime    @default(now()) @map("erstellt_am")
  geaendertAm   DateTime?   @map("geaendert_am")
  deletedAt     DateTime?   @map("deleted_at")

  tenant          Tenant              @relation(fields: [tenantId], references: [id])
  objekt          Objekt              @relation(fields: [objektId], references: [id])
  mietvertraege   Mietvertrag[]
  nkAbrechnungen  NkAbrechnung[]
  zaehler         Zaehler[]
  dokumente       Dokument[]
  lernmodusFragen LernmodusFrage[]
  lernwissen      EinheitLernwissen?

  @@index([objektId])
  @@index([tenantId])
  @@map("einheiten")
}

model Mieter {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  anrede       String?
  vorname      String?
  nachname     String
  firmenname   String?
  zusatz       String?
  strasse      String?
  hausnummer   String?
  plz          String?
  stadt        String?
  email        String?
  telefon      String?
  iban         String?
  steuernummer String?
  notizen      String?
  deletedAt    DateTime? @map("deleted_at")
  erstelltAm   DateTime  @default(now()) @map("erstellt_am")
  geaendertAm  DateTime? @map("geaendert_am")

  tenant            Tenant              @relation(fields: [tenantId], references: [id])
  mietvertragMieter MietvertragMieter[]
  dokumente         Dokument[]

  @@index([tenantId])
  @@map("mieter")
}

model Mietvertrag {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId               String    @map("tenant_id") @db.Uuid
  einheitId              String    @map("einheit_id") @db.Uuid
  mietart                Mietart
  vertragsbeginn         DateTime  @db.Date
  vertragsende           DateTime? @db.Date
  nettomiete             Decimal   @db.Decimal(10, 2)
  nkVorauszahlung        Decimal   @default(0) @map("nk_vorauszahlung") @db.Decimal(10, 2)
  kaution                Decimal?  @db.Decimal(10, 2)
  mietflaecheM2          Decimal?  @map("mietflaeche_m2") @db.Decimal(8, 2)
  indexKlausel           Boolean   @default(false) @map("index_klausel")
  indexTyp               String?   @map("index_typ")
  indexBasisjahr         Int?      @map("index_basisjahr")
  indexBasiswert         Decimal?  @map("index_basiswert") @db.Decimal(8, 3)
  kuendigungsfristMieter Int       @default(3) @map("kuendigungsfrist_mieter")
  kuendigungsfristVerm   Int       @default(3) @map("kuendigungsfrist_verm")
  notizen                String?
  erstelltAm             DateTime  @default(now()) @map("erstellt_am")
  erstelltVon            String?   @map("erstellt_von") @db.Uuid
  geaendertAm            DateTime? @map("geaendert_am")
  deletedAt              DateTime? @map("deleted_at")

  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  einheit            Einheit             @relation(fields: [einheitId], references: [id])
  ersteller          User?               @relation("VertragErsteller", fields: [erstelltVon], references: [id])
  mietvertragMieter  MietvertragMieter[]
  vertragsklauseln   Vertragsklausel[]
  nkAbrechnungen     NkAbrechnung[]
  matchingErgebnisse MatchingErgebnis[]
  offenePosten       OffenerPosten[]
  mieterhoehungen    Mieterhoehung[]
  dokumente          Dokument[]

  @@index([einheitId])
  @@index([tenantId])
  @@map("mietvertraege")
}

model MietvertragMieter {
  mietvertragId String    @map("mietvertrag_id") @db.Uuid
  mieterId      String    @map("mieter_id") @db.Uuid
  rolle         String    @default("hauptmieter")
  seit          DateTime  @db.Date
  bis           DateTime? @db.Date

  mietvertrag Mietvertrag @relation(fields: [mietvertragId], references: [id])
  mieter      Mieter      @relation(fields: [mieterId], references: [id])

  @@id([mietvertragId, mieterId])
  @@index([mieterId])
  @@map("mietvertrag_mieter")
}

model Vertragsklausel {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  mietvertragId String    @map("mietvertrag_id") @db.Uuid
  klauselTyp    String    @map("klausel_typ")
  inhalt        String
  gueltigAb     DateTime? @map("gueltig_ab") @db.Date
  gueltigBis    DateTime? @map("gueltig_bis") @db.Date
  betrag        Decimal?  @db.Decimal(10, 2)
  manuellPruefen Boolean  @default(true) @map("manuell_pruefen")
  erstelltAm    DateTime  @default(now()) @map("erstellt_am")

  mietvertrag Mietvertrag @relation(fields: [mietvertragId], references: [id])

  @@index([mietvertragId])
  @@map("vertragsklauseln")
}

model Kostenart {
  id                 String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String           @map("tenant_id") @db.Uuid
  kuerzel            String
  bezeichnung        String
  umlagefaehig       Umlagefaehig     @default(ja)
  schluesselStandard Umlageschluessel @default(wohnflaeche) @map("schluessel_standard")
  rechtsgrundlage    String?
  heizkvRelevant     Boolean          @default(false) @map("heizkv_relevant")
  systemVordefiniert Boolean          @default(false) @map("system_vordefiniert")
  aktiv              Boolean          @default(true)
  erstelltAm         DateTime         @default(now()) @map("erstellt_am")

  tenant           Tenant                     @relation(fields: [tenantId], references: [id])
  umlageschluessel UmlageschluesselEintrag[]
  kostenpositionen Kostenposition[]
  nkPositionen     NkPosition[]

  @@unique([tenantId, kuerzel])
  @@index([tenantId])
  @@map("kostenarten")
}

model UmlageschluesselEintrag {
  id                  String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            String           @map("tenant_id") @db.Uuid
  objektId            String           @map("objekt_id") @db.Uuid
  kostenartId         String           @map("kostenart_id") @db.Uuid
  schluesselTyp       Umlageschluessel @map("schluessel_typ")
  verbrauchsanteilPct Decimal?         @map("verbrauchsanteil_pct") @db.Decimal(5, 2)
  flaechenanteilPct   Decimal?         @map("flaechenanteil_pct") @db.Decimal(5, 2)
  heizkvGeprueft      Boolean          @default(false) @map("heizkv_geprueft")
  notizen             String?

  objekt    Objekt    @relation(fields: [objektId], references: [id])
  kostenart Kostenart @relation(fields: [kostenartId], references: [id])

  @@unique([objektId, kostenartId])
  @@index([objektId])
  @@map("umlageschluessel")
}

model Bankkonto {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  bezeichnung  String
  iban         String
  bic          String?
  kontoinhaber String
  bankName     String?  @map("bank_name")
  aktiv        Boolean  @default(true)
  erstelltAm   DateTime @default(now()) @map("erstellt_am")

  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  bankkontoObjekte BankkontoObjekt[]
  kontoauszuege    Kontoauszug[]

  @@unique([tenantId, iban])
  @@map("bankkonten")
}

model BankkontoObjekt {
  bankkontoId String @map("bankkonto_id") @db.Uuid
  objektId    String @map("objekt_id") @db.Uuid

  bankkonto Bankkonto @relation(fields: [bankkontoId], references: [id])
  objekt    Objekt    @relation(fields: [objektId], references: [id])

  @@id([bankkontoId, objektId])
  @@map("bankkonto_objekte")
}

model Lieferant {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  name         String
  strasse      String?
  plz          String?
  stadt        String?
  steuernummer String?
  iban         String?
  kostenartId  String?   @map("kostenart_id") @db.Uuid
  notizen      String?
  deletedAt    DateTime? @map("deleted_at")
  erstelltAm   DateTime  @default(now()) @map("erstellt_am")

  tenant           Tenant           @relation(fields: [tenantId], references: [id])
  kostenpositionen Kostenposition[]

  @@index([tenantId])
  @@map("lieferanten")
}

model Abrechnungszeitraum {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  objektId    String    @map("objekt_id") @db.Uuid
  bezeichnung String
  von         DateTime  @db.Date
  bis         DateTime  @db.Date
  status      String    @default("offen")
  erstelltAm  DateTime  @default(now()) @map("erstellt_am")
  erstelltVon String?   @map("erstellt_von") @db.Uuid
  deletedAt   DateTime? @map("deleted_at")

  tenant                Tenant                @relation(fields: [tenantId], references: [id])
  objekt                Objekt                @relation(fields: [objektId], references: [id])
  dokumente             Dokument[]
  kostenpositionen      Kostenposition[]
  nkAbrechnungen        NkAbrechnung[]
  verbrauchserfassungen Verbrauchserfassung[]

  @@index([objektId])
  @@map("abrechnungszeitraeume")
}

model Dokument {
  id                 String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String            @map("tenant_id") @db.Uuid
  zeitraumId         String?           @map("zeitraum_id") @db.Uuid
  einheitId          String?           @map("einheit_id") @db.Uuid
  objektId           String?           @map("objekt_id") @db.Uuid
  mieterId           String?           @map("mieter_id") @db.Uuid
  mietvertragId      String?           @map("mietvertrag_id") @db.Uuid
  dokumentKategorie  DokumentKategorie @default(sonstiges) @map("dokument_kategorie")
  dokumentTyp        String            @default("rechnung") @map("dokument_typ")
  titel              String?
  beschreibung       String?
  originalName       String            @map("original_name")
  s3Key              String            @unique @map("s3_key")
  mimeType           String            @map("mime_type")
  fileSizeBytes      BigInt            @map("file_size_bytes")
  sha256             String
  extractionStatus   ExtractionStatus  @default(pending) @map("extraction_status")
  extractedData      Json?             @map("extracted_data")
  uploadFehler       String?           @map("upload_fehler")
  hochgeladenAm      DateTime          @default(now()) @map("hochgeladen_am")
  hochgeladenVon     String            @map("hochgeladen_von") @db.Uuid

  tenant           Tenant               @relation(fields: [tenantId], references: [id])
  zeitraum         Abrechnungszeitraum? @relation(fields: [zeitraumId], references: [id])
  einheit          Einheit?             @relation(fields: [einheitId], references: [id])
  objekt           Objekt?              @relation(fields: [objektId], references: [id])
  mieter           Mieter?              @relation(fields: [mieterId], references: [id])
  mietvertrag      Mietvertrag?         @relation(fields: [mietvertragId], references: [id])
  extraktion       DokExtraktion?
  kostenpositionen Kostenposition[]
  lernmodusSession LernmodusSession?

  @@index([zeitraumId])
  @@index([einheitId])
  @@index([objektId])
  @@index([mieterId])
  @@index([mietvertragId])
  @@index([sha256])
  @@index([tenantId, dokumentKategorie])
  @@map("dokumente")
}

model DokExtraktion {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  dokumentId      String    @unique @map("dokument_id") @db.Uuid
  rawResponse     Json      @map("raw_response")
  extractedFields Json      @map("extracted_fields")
  confidenceMap   Json      @map("confidence_map")
  flags           String[]  @default([])
  modelVersion    String    @map("model_version")
  promptVersion   String    @map("prompt_version")
  tokensInput     Int?      @map("tokens_input")
  tokensOutput    Int?      @map("tokens_output")
  extrahiertAm    DateTime  @default(now()) @map("extrahiert_am")
  reviewed        Boolean   @default(false)
  reviewedVon     String?   @map("reviewed_von") @db.Uuid
  reviewedAm      DateTime? @map("reviewed_am")
  reviewNotizen   String?   @map("review_notizen")

  dokument Dokument @relation(fields: [dokumentId], references: [id])
  reviewer User?    @relation("ExtractionReviewer", fields: [reviewedVon], references: [id])

  @@index([reviewed])
  @@map("dok_extraktionen")
}

model Kostenposition {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String    @map("tenant_id") @db.Uuid
  zeitraumId        String    @map("zeitraum_id") @db.Uuid
  dokumentId        String?   @map("dokument_id") @db.Uuid
  kostenartId       String    @map("kostenart_id") @db.Uuid
  lieferantId       String?   @map("lieferant_id") @db.Uuid
  rechnungsdatum    DateTime  @db.Date
  rechnungsnummer   String?
  periodeVon        DateTime? @map("periode_von") @db.Date
  periodeBis        DateTime? @map("periode_bis") @db.Date
  nettobetrag       Decimal   @db.Decimal(10, 2)
  bruttobetrag      Decimal   @db.Decimal(10, 2)
  mwstSatz          Decimal?  @map("mwst_satz") @db.Decimal(5, 2)
  beschreibung      String?
  erfassungsquelle  String    @default("ki_extraktion")
  manuellKorrigiert Boolean   @default(false) @map("manuell_korrigiert")
  nichtUmlagefaehig Boolean   @default(false) @map("nicht_umlagefaehig")
  erstelltAm        DateTime  @default(now()) @map("erstellt_am")
  erstelltVon       String?   @map("erstellt_von") @db.Uuid

  tenant       Tenant              @relation(fields: [tenantId], references: [id])
  zeitraum     Abrechnungszeitraum @relation(fields: [zeitraumId], references: [id])
  dokument     Dokument?           @relation(fields: [dokumentId], references: [id])
  kostenart    Kostenart           @relation(fields: [kostenartId], references: [id])
  lieferant    Lieferant?          @relation(fields: [lieferantId], references: [id])
  nkPositionen NkPosition[]
  oelZukaeufe  OelZukauf[]

  @@index([zeitraumId])
  @@index([kostenartId])
  @@map("kostenpositionen")
}

model NkAbrechnung {
  id                      String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId                String           @map("tenant_id") @db.Uuid
  zeitraumId              String           @map("zeitraum_id") @db.Uuid
  mietvertragId           String           @map("mietvertrag_id") @db.Uuid
  einheitId               String           @map("einheit_id") @db.Uuid
  status                  AbrechnungStatus @default(entwurf)
  abrechnungsbeginn       DateTime         @db.Date
  abrechnungsende         DateTime         @db.Date
  bewohnungstage          Int
  zeitraumTage            Int              @map("zeitraum_tage")
  anteilsfaktor           Decimal          @db.Decimal(8, 6)
